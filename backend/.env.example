# Optional legacy FastAPI backend variables. The deployed Next.js app no longer
# needs this backend for analysis, auth, saved history, or insight generation.

# OpenAI API key used only by the legacy /ai/explain FastAPI endpoint.
OPENAI_API_KEY=sk-your-openai-api-key

# OpenAI model name for the legacy /ai/explain FastAPI endpoint.
OPENAI_MODEL=gpt-4o-mini

# Allowed frontend origin for legacy FastAPI CORS.
FRONTEND_ORIGIN=http://localhost:3000

# JWT signing secret for legacy FastAPI auth.
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Legacy FastAPI JWT expiration in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional Supabase project URL for the legacy backend/database setup.
SUPABASE_URL=https://your-project.supabase.co

# Optional Supabase anon key for the legacy backend/database setup.
SUPABASE_ANON_KEY=your-supabase-anon-key

# PostgreSQL URL for the legacy FastAPI saved analyses database.
DATABASE_URL=postgresql+psycopg://postgres:YOUR-PASSWORD@db.your-project.supabase.co:5432/postgres
